@layer properties {
  @property --bg-position {
    syntax: "<number>"; inherits: true; initial-value: 100;
  }

  @property --after-blur {
    syntax: "<number>"; inherits: true; initial-value: 0;
  }

  @property --after-opacity {
    syntax: "<number>"; inherits: true; initial-value: 1;
  }

  @property --before-opacity {
    syntax: "<number>"; inherits: true; initial-value: .3;
  }

  @property --btn-offset {
    syntax: "<number>"; inherits: true; initial-value: 1;
  }

  @property --btn-scale {
    syntax: "<number>"; inherits: true; initial-value: 1;
  }
}

:root {
  --bg-position: 100;
  --btn-border-width: 1.5;
  --after-blur: 10;
  --after-pos-y: 10;
  --after-opacity: 1;
  --before-opacity: .3;
  --btn-offset: 1;
  --btn-scale: 1;
}

.hidden {
  visibility: hidden;
}

body {
  color: #fff;
  background: radial-gradient(circle, #0b0d1f 0%, #090b17 60%, #06070e 100%);
  height: 100%;
  font-family: Inter, sans-serif;
  font-size: clamp(1.4rem, 1.5vw, 1.6rem);
}

main {
  flex: 1;
}

.trigger-wrapper {
  z-index: 100;
  justify-content: center;
  align-items: center;
  margin: 20px;
  transition: transform .4s;
  display: flex;
}

.trigger-wrapper:hover {
  transform: scale(1.1);
}

@media (width >= 1024px) {
  .trigger-wrapper {
    position: fixed;
    top: 3rem;
    right: 2rem;
  }
}

.trigger-wrapper .capsule-trigger {
  cursor: pointer;
  background-color: #0000;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  width: 50px;
  height: 40px;
  padding: 0;
  transition: transform .4s, background-color .4s;
  display: flex;
  position: relative;
}

@media (width >= 1024px) {
  .trigger-wrapper .capsule-trigger {
    align-items: flex-end;
  }
}

.trigger-wrapper .capsule-trigger .bar {
  background: linear-gradient(90deg, #fff, #fff6);
  border-radius: 2px;
  height: 3px;
  transition: transform .4s, opacity .4s;
}

.trigger-wrapper .capsule-trigger .bar-top, .trigger-wrapper .capsule-trigger .bar-bottom {
  width: 100%;
}

.trigger-wrapper .capsule-trigger .bar-middle {
  width: 60%;
  margin: 0 auto;
}

.trigger-wrapper .capsule-trigger.active .bar-top {
  opacity: 0;
  transform: translateX(-80px);
}

.trigger-wrapper .capsule-trigger.active .bar-bottom {
  opacity: 0;
  transform: translateX(80px);
}

.trigger-wrapper .capsule-trigger.active .bar-middle {
  background: linear-gradient(270deg, #fff, #090b17);
  width: 100%;
  animation: 1.5s ease-in-out infinite pulse-glow;
}

.back-btn {
  cursor: pointer;
  color: #ccc;
  background-color: #1f254e;
  border: none;
  border-radius: 50%;
  justify-content: center;
  align-items: center;
  margin-left: 2rem;
  padding: 1.5rem;
  transition: background-color .2s, transform .2s;
  display: flex;
  top: 100%;
  box-shadow: 0 2px 6px #00000080;
}

.back-btn .arrow-icon {
  transition: transform .2s;
}

.back-btn:hover {
  color: #fff;
  background-color: #2d3773;
}

.back-btn:hover .arrow-icon {
  transform: translateX(-2px);
}

.back-btn:active {
  transform: scale(.95);
}

.scrollTopBtn {
  opacity: 0;
  cursor: pointer;
  background: linear-gradient(145deg, #6c63ffcc, #6a00f4cc);
  border: 2px solid #fff3;
  border-radius: 50%;
  width: 5rem;
  height: 5rem;
  display: none;
  position: fixed;
  bottom: 3rem;
  right: 3rem;
}

@media (width >= 1024px) {
  .scrollTopBtn {
    pointer-events: none;
    z-index: 20;
    justify-content: center;
    align-items: center;
    transition: all .3s;
    display: flex;
    transform: scale(.8);
  }

  .scrollTopBtn svg.arrow-svg {
    stroke: #fff;
    stroke-dasharray: 40;
    stroke-dashoffset: 40px;
    width: 2.4rem;
    height: 2.4rem;
    animation: 1s forwards drawArrow;
  }

  .scrollTopBtn:hover {
    background: linear-gradient(135deg, #847dff, #770fff);
    box-shadow: 0 0 1rem #ba86fc99;
  }

  .scrollTopBtn:active {
    transform: scale(.95);
    box-shadow: 0 0 .4rem #ba86fc4d;
  }

  .scrollTopBtn[style*="display: block"] {
    pointer-events: auto;
    animation: .4s forwards fadeInUp, 2s .5s infinite pulse;
  }
}

.submit-btn {
  all: unset;
  background: none;
  border-width: 0;
  width: 80%;
  margin: 2rem auto;
  transition: --bg-position 3s, --after-blur .3s, --before-opacity .3s, --btn-offset .3s, --btn-scale .2s cubic-bezier(.76, -.25, .51, 1.13);
  transform: scale(1);
}

.submit-btn > div {
  color: #fff;
  cursor: pointer;
  text-align: center;
  background: #090b17;
  border-radius: 8px;
  padding: 1em 1.2em;
  font-weight: 700;
  display: block;
  position: relative;
}

.submit-btn > div:not(:hover) {
  transition: --after-blur .3s;
}

.submit-btn span {
  background: linear-gradient(to right, #fff, #fff, #0ff, #00f, #8000ff, #d194b3, red, #ff0, #bfff80, #fff, #fff) no-repeat calc(var(--bg-position) * 1%) 0% / 900%;
  color: #0000;
  -webkit-text-fill-color: transparent;
  letter-spacing: .15ch;
  background-clip: text;
  font-weight: 700;
}

.submit-btn:after {
  content: "";
  background: linear-gradient(to right, #000, #000, #000, #000, #000, #000, #000, #000, #000, #000, #000, #000, #000, #000) no-repeat calc(var(--bg-position) * 1%) 0% / 900%;
  width: 100%;
  height: 100%;
  transform: translateY(calc(var(--after-pos-y) * 1px));
  z-index: -2;
  filter: blur(calc(var(--after-blur) * 1px));
  opacity: var(--after-opacity);
  display: block;
  position: absolute;
  top: 0;
  left: 0;
}

.submit-btn:before {
  content: "";
  width: calc(100% + var(--btn-border-width) * 2 * 1px);
  height: calc(100% + var(--btn-border-width) * 2 * 1px);
  background: linear-gradient(to right, #fff, #fff, #0ff, #00f, #8000ff, #d194b3, red, #ff0, #bfff80, #fff, #fff) no-repeat calc(var(--bg-position) * 1%) 0% / 900%;
  z-index: -1;
  top: calc(var(--btn-border-width) * -1px);
  left: calc(var(--btn-border-width) * -1px);
  opacity: var(--before-opacity);
  border-radius: 9px;
  display: block;
  position: absolute;
}

.submit-btn:hover {
  --btn-scale: 1.05;
  --bg-position: 0;
  --after-bg: linear-gradient(to right, v. $ blanco, v. $ blanco, v. $ color-cyan, v. $ color-blue, v. $ color-purple, v. $ color-pink, v. $ color-red, v. $ color-yellow, v. $ color-lime, v. $ blanco, v. $ blanco);
  --after-blur: 30;
  --after-opacity: .3;
  --after-pos-y: 0;
  --before-opacity: 1;
  --btn-offset: 5;
}

.submit-btn:hover:active {
  --btn-scale: .98;
  --after-blur: 15;
  transform: scale(.96);
}

.common-more-moreAll, .more_all, .more {
  text-transform: uppercase;
  text-align: center;
  cursor: pointer;
  z-index: 1;
  color: #0000;
  -webkit-text-fill-color: transparent;
  background-image: linear-gradient(90deg, #ce9ffc66 0%, #fff 25%, #ce9ffcb3 50% 100%);
  background-position: 100% 0;
  background-size: 400%;
  background-clip: text;
  border: none;
  width: 100%;
  padding: 1rem 2rem;
  font-size: clamp(1.3rem, 1.4vw, 1.5rem);
  font-weight: 700;
  transition: background-position .6s, transform .3s, box-shadow .3s;
  display: inline-block;
  position: relative;
  box-shadow: inset 0 0 .5px #ffffff0d, 0 4px 14px #ce9ffc40, 0 0 0 .5px #ffffff0a;
}

.common-more-moreAll:before, .more_all:before, .more:before {
  content: "";
  z-index: -1;
  -webkit-mask-composite: xor;
  background: linear-gradient(90deg, #ce9ffc66 0%, #fff 25%, #ce9ffc66 50% 100%) 100% 0 / 400%;
  border-radius: .5rem;
  padding: 2px;
  transition: background-position .6s;
  position: absolute;
  inset: -2px;
  mask-image: linear-gradient(#fff 0 0), linear-gradient(#fff 0 0);
  mask-position: 0 0, 0 0;
  mask-size: auto, auto;
  mask-repeat: repeat, repeat;
  mask-clip: content-box, border-box;
  mask-origin: content-box, border-box;
  mask-composite: exclude;
  mask-mode: match-source, match-source;
}

.common-more-moreAll:hover, .more_all:hover, .more:hover, .common-more-moreAll:hover:before, .more_all:hover:before, .more:hover:before {
  background-position: 0 0;
}

.common-more-moreAll:active, .more_all:active, .more:active {
  transform: scale(.98);
  box-shadow: 0 2px 6px #ce9ffc33;
}

.common-more-moreAll:active:before, .more_all:active:before, .more:active:before {
  background-position: 12.5% 0;
}

.more {
  font-size: clamp(1.3rem, 1.4vw, 1.5rem);
}

.more-wrapper {
  background: linear-gradient(135deg, #3c3352, #4b3b61);
  justify-content: center;
  max-width: 280px;
  margin: 1rem auto;
  display: flex;
}

.more_all {
  font-size: clamp(1.1rem, 1.2vw, 1.4rem);
}

.more_all-wrapper {
  background: linear-gradient(145deg, #2a2a40, #3e3e60);
  justify-content: center;
  max-width: 350px;
  margin: 5rem auto 0;
  display: flex;
}

.contacto-form {
  text-align: left;
  backdrop-filter: blur(12px);
  z-index: 2;
  background: linear-gradient(145deg, #090b17, #1a1a2ee6);
  border: 2px solid #0000;
  border-radius: 2rem;
  flex-direction: column;
  align-content: center;
  gap: clamp(1rem, 2rem, 1rem + 1.5vw);
  width: 90%;
  margin: 5rem auto;
  padding: 1.5rem;
  transition: all .3s;
  animation: 1s forwards softAppear;
  display: flex;
  position: relative;
  box-shadow: 1px 1px .5rem #ce9ffc33, 0 0 2rem #0006;
}

@media (width >= 768px) {
  .contacto-form {
    max-width: 70%;
  }
}

@media (width >= 1024px) {
  .contacto-form {
    max-width: 60%;
  }
}

.contacto-form__fieldset {
  background: linear-gradient(135deg, #090b171a, #090b1799);
  border: 1px solid #fff6;
  border-radius: 1.2rem;
  flex-direction: column;
  gap: clamp(1rem, 1rem + 2vw, 3rem);
  max-width: 100%;
  padding: 2.5rem;
  transition: all .4s;
  display: flex;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
  box-shadow: inset 0 0 4px #fff6, 0 5px 20px #000000e6;
}

.contacto-form__fieldset:focus-within {
  transform: scale(1.02), translateX(50%);
  border-color: #ffffff80;
  box-shadow: 0 0 8px #ffffff4d, 0 0 15px #6c63ff4d, inset 0 0 15px #0006;
}

.contacto-form legend {
  color: #0000;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 6px #ce9ffc33;
  background: linear-gradient(90deg, #ce9ffc, #7367f0) text;
  font-size: clamp(1.4rem, 1.6vw, 1.8rem);
  font-weight: 700;
  position: relative;
}

.contacto-form label {
  color: #f0f0f0;
  letter-spacing: .5px;
  margin-bottom: .4rem;
  font-size: clamp(1.3rem, 1.4vw, 1.5rem);
  font-weight: 500;
}

@media (width >= 1024px) {
  .contacto-form label {
    padding: 2rem;
  }
}

.contacto-form__input, .contacto-form textarea, .contacto-form input:not([type="submit"]) {
  color: #fff;
  background: #ffffff0d;
  border: 1px solid #ffffff26;
  border-radius: 1rem;
  width: 100%;
  margin: 1rem auto;
  padding: 1.2rem 1.6rem;
  font-family: Inter, sans-serif;
  font-size: clamp(1.3rem, 1.4vw, 1.5rem);
  transition: all .3s;
  position: relative;
  box-shadow: inset 0 0 3rem #0009, 0 0 5px #6c63ff0d;
}

.contacto-form__input::placeholder, .contacto-form textarea::placeholder, .contacto-form input:not([type="submit"])::placeholder {
  color: #ffffff80;
}

.contacto-form__input:focus, .contacto-form textarea:focus, .contacto-form input:not([type="submit"]):focus {
  background: #ffffff08;
  border-color: #ce9ffc;
  outline: none;
  transform: scale(1.03);
  box-shadow: 0 0 0 3px #ce9ffc40;
}

.contacto-form input[type="radio"] {
  appearance: none;
  cursor: pointer;
  background: linear-gradient(145deg, #2a2a40, #1b1b2e);
  border: none;
  border-radius: 50%;
  width: 2.4rem;
  height: 2.4rem;
  margin-right: .8rem;
  transition: all .25s ease-in-out;
  position: relative;
  box-shadow: inset -3px -3px 6px #ffffff14, inset 3px 3px 8px #0006, 0 4px 8px #00000080;
}

.contacto-form input[type="radio"]:hover {
  transform: scale(1.05);
  box-shadow: inset -2px -2px 4px #ffffff1a, inset 2px 2px 6px #00000073, 0 0 10px #7367f066;
}

.contacto-form input[type="radio"]:checked {
  background: radial-gradient(circle, #7367f0 40%, #2a2a40 100%);
  box-shadow: inset -2px -2px 6px #ffffff1a, inset 2px 2px 8px #00000073, 0 0 12px #7367f099;
}

.contacto-form input[type="radio"]:focus {
  outline: none;
  transform: scale(1.2);
  box-shadow: inset -2px -2px 6px #ffffff1a, inset 2px 2px 8px #00000073, 0 0 12px #7367f099;
}

.contacto-form .forma-contacto {
  justify-content: center;
  align-items: center;
  gap: clamp(1rem, 1rem + 1.5vw, 2rem);
  margin: 1rem auto;
  padding: 1rem;
  display: flex;
}

.contacto-form .contacto-form__fieldset .label:empty {
  display: none;
}

.contacto-form__textarea {
  resize: vertical;
  color: #ffffff80;
  width: 100%;
  min-height: 150px;
  font-family: Inter, sans-serif;
}

.login-form {
  backdrop-filter: blur(15px);
  z-index: 2;
  background: linear-gradient(145deg, #090b17, #1a1a2ee6);
  border: 2px solid #0000;
  border-radius: 2rem;
  flex-direction: column;
  align-content: center;
  gap: clamp(1rem, 1rem + 1vw, 2rem);
  width: 100%;
  padding: 2.5rem;
  transition: all .3s;
  animation: 1s forwards softAppear;
  display: flex;
  position: relative;
  box-shadow: 0 0 30px #0009;
}

.login-form__fieldset {
  background: linear-gradient(135deg, #090b171a, #090b1799);
  border: 3px solid #fff3;
  border-radius: 1.2rem;
  flex-direction: column;
