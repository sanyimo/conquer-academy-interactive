  background: linear-gradient(to right, #7f5af0, #00ffc3);
  box-shadow: 0 0 8px #00ffc3;
}

.qs_slider-arrows label {
  display: none;
}

#slide1:checked ~ .qs_slider-arrows label:first-child, #slide1:checked ~ .qs_slider-arrows label:nth-child(2), #slide2:checked ~ .qs_slider-arrows label:nth-child(3), #slide2:checked ~ .qs_slider-arrows label:nth-child(4), #slide3:checked ~ .qs_slider-arrows label:nth-child(5), #slide3:checked ~ .qs_slider-arrows label:nth-child(6), #slide4:checked ~ .qs_slider-arrows label:nth-child(7), #slide4:checked ~ .qs_slider-arrows label:nth-child(8) {
  display: block;
}

