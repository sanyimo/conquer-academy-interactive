.registro-form .next-page:hover, .registro-form .prev-page:hover {
  text-shadow: 0 0 6px #fff6;
  background: linear-gradient(145deg, #3e3e60, #5c5c80);
  transform: translateY(-3px);
  box-shadow: 0 6px 18px #ce9ffc66, 0 0 0 1px #ffffff14;
}

.registro-form .next-page:active, .registro-form .prev-page:active {
  transform: scale(.98);
  box-shadow: 0 2px 6px #ce9ffc33;
}

.registro-form .next-page:focus, .registro-form .prev-page:focus {
  outline: none;
  box-shadow: 0 0 0 3px #ce9ffc59;
}

.login-form__input.valid, .contacto-form__input.valid, .registro-form__input.valid, textarea.valid {
  border-color: #00ffe0;
  box-shadow: 0 0 3px #00ffe080;
}

.login-form__input.error, .contacto-form__input.error, .registro-form__input.error, textarea.error {
  border-color: #e25555;
  box-shadow: 0 0 3px #e2555580;
}

@keyframes auroraBackground {
  0% {
    background-position: 250%;
  }

  50% {
    background-position: 0%;
  }

  100% {
    background-position: 250%;
  }
}

@keyframes drawArrow {
  to {
    stroke-dashoffset: 0;
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeText {
  0% {
    opacity: 0;
  }

  10% {
    opacity: 1;
  }

  30% {
    opacity: 1;
  }

  40% {
    opacity: 0;
  }

  100% {
    opacity: 0;
  }
}

@keyframes gradientMove {
  0% {
    background-position: 0%;
