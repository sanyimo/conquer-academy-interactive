}

@media (width >= 768px) {
  .qs_team-title {
    font-size: 3rem;
  }
}

.qs_team-text {
  color: #fffc;
  max-width: 90%;
  margin-bottom: 3rem;
  margin-left: auto;
  margin-right: auto;
}

.qs_team-member {
  text-align: center;
  cursor: default;
  background: linear-gradient(#1a1a2e, #3f3d56, #6c63ff, #7872f1, #947af6, #a18ced, #aba6f1, #a29bfe, #a18ced, #947af6, #6c63ff, #3f3d56, #1a1a2e, #000 90%);
  border: 1rem solid #0006;
  border-radius: .8rem;
  flex-direction: column;
  width: 100%;
  max-width: 100%;
  height: 100%;
  margin: 1.5rem auto;
  display: flex;
  position: relative;
  overflow: hidden;
  box-shadow: 1px 1px 2px #e6e6e6;
}

@media (width >= 768px) {
  .qs_team-member {
    vertical-align: top;
    max-width: 45%;
    margin: 1rem;
    display: inline-block;
  }
}

@media (width >= 1024px) {
  .qs_team-member {
    max-width: 38%;
    margin: 0 auto;
  }

  .qs_team-member:last-of-type {
    box-shadow: 10px 10px 200px #e6e6e666;
  }
}

@media (width >= 1200px) {
  .qs_team-member {
    max-width: 30%;
  }
}

@media (width >= 1440px) {
  .qs_team-member {
    max-width: 26%;
  }
}

.qs_team-member .mask {
  flex-direction: column;
  width: 100%;
  height: 100%;
  transition: all .5s linear;
  display: flex;
  position: absolute;
  top: 0;
  left: 0;
  overflow: hidden;
}

.qs_team-member img {
  object-fit: cover;
  width: 100%;
  height: auto;
  transition: all .7s ease-in-out;
  display: block;
  transform: scaleY(1);
}

.qs_team-member h3 {
  text-transform: uppercase;
  text-align: center;
  opacity: 0;
  color: #fff;
  background: none;
  border-bottom: 1px solid #ffffff4d;
  margin-bottom: .5rem;
  padding: 0 1rem 1rem;
  font-size: 1.8rem;
  transition: all .5s linear;
  transform: scale(0);
}

.qs_team-member p {
  text-align: center;
  opacity: 0;
  color: #fffc;
  margin-bottom: 1rem;
  padding: 0 2rem 1rem;
  transition: all .5s linear;
  position: relative;
  transform: scale(0);
}

.qs_team-member:hover img, .qs_team-member:active img {
  opacity: 0;
  transform: scale(10);
}

.qs_team-member:hover .mask, .qs_team-member:active .mask {
  opacity: 1;
  background-color: #090b17b3;
}

.qs_team-member:hover h3, .qs_team-member:hover p, .qs_team-member:active h3, .qs_team-member:active p {
  opacity: 1;
  transform: scale(1);
}

.registro-body {
  flex-direction: column;
  min-height: 100vh;
  display: flex;
}

.registro {
  perspective: 1200px;
  transform-style: preserve-3d;
  flex-direction: column;
  flex: 1;
  align-items: center;
  padding: 2rem;
  display: flex;
}

.registro:before {
  content: "";
  opacity: .4;
  filter: blur(5px);
  z-index: -1;
  background: url("grafico.2459f98a.svg") center / cover no-repeat fixed;
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.registro .form-pages {
  flex-direction: column;
  width: 100%;
  display: flex;
  position: relative;
}

.registro .form-pages .page {
  animation: .3s fadeIn;
  display: none;
}

.registro .form-pages .page-radio:checked + .page {
  display: block;
}

.registro .next-page, .registro .prev-page {
  text-align: center;
  width: 100%;
  margin-top: 1rem;
}

.registro-title {
  text-align: center;
  letter-spacing: 1.5px;
  text-shadow: 0 0 50px #6c63ff4d;
  max-width: 90%;
  margin: 0 auto;
  padding: 2rem;
}

.registro-footer {
  width: 100%;
  display: grid;
  bottom: 0;
}

.registro-footer .footer-top {
  width: 100%;
  margin-bottom: 0;
}

@media (width >= 1024px) {
  .registro-footer .footer-bottom {
    justify-self: end;
  }
}

@media (width >= 768px) {
  .registro-footer {
    grid-template-columns: 1fr;
    padding-bottom: 3rem;
  }
}

@media (width >= 1024px) {
  .registro-footer {
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 2rem);
    padding: 1rem 5rem;
    font-size: 1.2rem;
  }
}

@media (width >= 1200px) {
  .registro-footer {
    padding: 2rem 10rem;
  }
}

@media (width >= 1440px) {
  .registro-footer {
    padding: 3rem 15rem;
  }
}
