}

.login-form label {
  color: #f0f0f0;
  letter-spacing: .5px;
  margin-bottom: .4rem;
  font-size: clamp(1.3rem, 1.4vw, 1.5rem);
  font-weight: 500;
  display: block;
}

.login-form__group {
