  cursor: pointer;
  color: #fff;
  backdrop-filter: blur(6px);
  background: linear-gradient(145deg, #2a2a40, #3e3e60);
  border: 2px solid #ce9ffc66;
  border-radius: .6rem;
  width: 100%;
  max-width: 280px;
  padding: 1.1rem 2rem;
