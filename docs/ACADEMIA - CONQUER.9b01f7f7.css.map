.qs_slider {
  color: #fff;
  perspective: 1200px;
  background: linear-gradient(to bottom right, #0b0d1a, #111429);
  border-radius: 2rem;
  width: 100%;
  max-width: 900px;
  margin: 4rem auto;
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 3rem #0000004d;
}

.qs_slider input[type="radio"] {
  display: none;
}

.qs_slider .qs_slider-wrapper {
  transform-style: preserve-3d;
  grid-template-columns: repeat(4, 100%);
  transition: transform .8s ease-in-out;
  display: grid;
}

.qs_slider .qs_slide {
  text-align: center;
  opacity: .2;
  background: linear-gradient(145deg, #1a1e2c, #0e0f1d);
  flex-direction: column;
  justify-content: center;
  padding: 2rem;
  transition: opacity .8s, transform .8s;
  display: flex;
  transform: rotateY(15deg)translateZ(-200px);
  box-shadow: inset 0 0 2rem #ffffff0d;
}

.qs_slider .qs_slide:before {
  content: "";
  z-index: -1;
  filter: blur(6px);
  background-image: url("grafico-no-square.abdbe8ed.svg");
  background-position: center;
  background-repeat: no-repeat;
  background-size: 30%;
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  transform: rotateY(180deg);
}

.qs_slider .qs_slide h2 {
  color: #a382ff;
  margin-bottom: 2rem;
}

.qs_slider .qs_slide h2:after {
  display: none;
}

.qs_slider .qs_slide p {
  margin: 0 0 2rem;
  padding: 1rem;
  transition: transform .5s;
  transform: rotateY(10deg);
}

.qs_slider .qs_values-boxes {
  gap: clamp(1rem, 2rem, 1rem + 1.5vw);
  display: grid;
}

@media (width >= 768px) {
  .qs_slider .qs_values-boxes {
    grid-template-columns: repeat(2, 1fr);
  }
}

.qs_slider .qs_values-boxes .qs_value-box {
  backdrop-filter: blur(6px);
  background: #ffffff0d;
  border: 1px solid #ffffff1a;
  border-radius: 1rem;
  padding: 1rem;
  box-shadow: 0 0 10px #ffffff0d;
}

.qs_slider .qs_values-boxes .qs_value-box h3 {
  color: #a382ff;
  margin-bottom: .5rem;
}

.qs_slider #slide1:checked ~ .qs_slider-wrapper {
  transform: translateX(0);
}

.qs_slider #slide2:checked ~ .qs_slider-wrapper {
  transform: translateX(-100%);
}

.qs_slider #slide3:checked ~ .qs_slider-wrapper {
  transform: translateX(-200%);
}

.qs_slider #slide4:checked ~ .qs_slider-wrapper {
  transform: translateX(-300%);
}

.qs_slider .qs_slider-controls {
  background: linear-gradient(145deg, #1a1e2c, #0e0f1d);
  border-radius: 1rem;
  justify-content: center;
  gap: clamp(1rem, .5rem + 1vw, 1.5rem);
  padding: clamp(1rem, 1.5rem, 1rem + .5vw);
  display: flex;
}

.qs_slider .qs_slider-controls label {
  cursor: pointer;
  background: #444;
  border-radius: 50%;
  width: 1rem;
  height: 1rem;
  transition: background .3s;
}

.qs_slider .qs_slider-controls label:hover {
  background: #a382ff;
}

.qs_slider #slide1:checked ~ .qs_slider-wrapper .qs_slide:first-child, .qs_slider #slide2:checked ~ .qs_slider-wrapper .qs_slide:nth-child(2), .qs_slider #slide3:checked ~ .qs_slider-wrapper .qs_slide:nth-child(3), .qs_slider #slide4:checked ~ .qs_slider-wrapper .qs_slide:nth-child(4) {
  opacity: 1;
  transform: rotateY(0)translateZ(0);
}

.qs_slider #slide1:checked ~ .qs_slider-controls label:first-child, .qs_slider #slide2:checked ~ .qs_slider-controls label:nth-child(2), .qs_slider #slide3:checked ~ .qs_slider-controls label:nth-child(3), .qs_slider #slide4:checked ~ .qs_slider-controls label:nth-child(4) {
  background: linear-gradient(to right, #7f5af0, #00ffc3);
  box-shadow: 0 0 8px #00ffc3;
}

.qs_slider-arrows {
  pointer-events: none;
  justify-content: space-between;
  width: 100%;
  display: flex;
  position: absolute;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

.qs_slider-arrows label {
  backdrop-filter: blur(5px);
  pointer-events: all;
  cursor: pointer;
  background: #ffffff1a;
  border: 2px solid #fff3;
  border-radius: 50%;
  width: 3rem;
  height: 3rem;
  margin: 0 .5rem;
  transition: all .3s;
  box-shadow: 0 0 8px #0006;
}

